# Copy this file to ".env" and fill in the values.
#
# Discord bot token from the Developer Portal (Bot -> Reset Token)
DISCORD_TOKEN=

# Your application's client (application) ID (General Information -> Application ID)
CLIENT_ID=

# Optional: a guild (server) ID for instant, guild-scoped slash command registration during development.
# Leave empty to register commands globally (can take up to ~1 hour to propagate).
GUILD_ID=

# Comma-separated channel IDs where the bot auto-creates a comments thread when
# someone posts a qualifying social post link (X/Twitter, Bluesky, Aethy) or a
# direct image/video. Requires the privileged "Message Content" intent (enable it
# in the Developer Portal -> Bot -> Privileged Gateway Intents).
AUTOTHREAD_CHANNEL_IDS=

# Channel where the welcome card image is posted when a member joins. Leave empty
# to disable the welcome module. Requires the privileged "Server Members" intent
# (Developer Portal -> Bot -> Privileged Gateway Intents).
WELCOME_CHANNEL_ID=

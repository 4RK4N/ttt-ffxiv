# Copy this file to ".env" and fill in the values.
#
# Discord bot token from the Developer Portal (Bot -> Reset Token)
DISCORD_TOKEN=

# Your application's client (application) ID (General Information -> Application ID)
CLIENT_ID=

# Optional: a guild (server) ID for instant, guild-scoped slash command registration during development.
# Leave empty to register commands globally (can take up to ~1 hour to propagate).
GUILD_ID=

# Comma-separated channel IDs where the bot auto-creates a comments thread when
# someone posts a qualifying social post link (X/Twitter, Bluesky, Aethy) or a
# direct image/video. Requires the privileged "Message Content" intent (enable it
# in the Developer Portal -> Bot -> Privileged Gateway Intents).
AUTOTHREAD_CHANNEL_IDS=

# Channel where the welcome card image is posted when a member joins. Leave empty
# to disable the welcome module. Requires the privileged "Server Members" intent
# (Developer Portal -> Bot -> Privileged Gateway Intents).
WELCOME_CHANNEL_ID=

# Display name shown in the web editor's title ("<BOT_NAME> Admin Interface").
# Defaults to "TTT" if left empty.
BOT_NAME=

# --- Web text editor (separate "ttt-web-editor" container) ---------------------
# The editor lets guild administrators edit each module's texts via a browser.
# It is secured with Discord OAuth and only allows users who have the
# Administrator permission on GUILD_ID, so GUILD_ID is REQUIRED for the editor.
#
# OAuth2 client secret (Developer Portal -> OAuth2 -> Client Secret -> Reset).
CLIENT_SECRET=
#
# A long random string used to sign the editor's session cookies. Generate one,
# e.g. with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
#
# OAuth2 redirect URL. Must be added verbatim under Developer Portal ->
# OAuth2 -> Redirects. Use the editor's public "/callback" URL behind your proxy
# (https makes the session cookie "Secure" automatically). For local dev without
# a proxy, use http://localhost:8088/callback instead.
OAUTH_REDIRECT_URI=
#
# Port the editor listens on inside the container. Caddy proxies to this port
# (see docker-compose.yml: caddy.reverse_proxy "{{upstreams 8088}}"), so if you
# change this you must update that label too. Defaults to 8088 if unset.
WEB_PORT=

{
  "name": "ttt-bot",
  "version": "0.1.0",
  "description": "Custom Discord bot for Tiny Temptation Tubs (TTT) with an extensible module system.",
  "type": "module",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "deploy": "node dist/scripts/deploy-commands.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}

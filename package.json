{
  "name": "ttt-bot",
  "version": "1.0.0",
  "description": "Custom Discord bot for Tiny Temptation Tubs (TTT) with an extensible module system.",
  "type": "module",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-web-plugins.js",
    "start": "node dist/src/index.js",
    "deploy": "node dist/scripts/deploy-commands.js",
    "dev": "tsx src/index.ts",
    "web": "node dist/src/web/server.js",
    "web:dev": "tsx src/web/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@napi-rs/canvas": "^1.0.2",
    "discord.js": "^14.26.4",
    "hono": "^4.12.27"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tabler/core": "^1.4.0",
    "@types/node": "^24.13.0",
    "eslint": "^9.39.2",
    "globals": "^17.7.0",
    "prettier": "^3.8.1",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}

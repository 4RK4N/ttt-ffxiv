---
import Base from "../layouts/Base.astro";
import OrnamentDivider from "./OrnamentDivider.astro";
import type { Lang } from "../data/nav";

interface Props {
  title: string;
  lang: Lang;
  path: string;
  heading: string;
  /** Overrides site default for meta / og:description. */
  description?: string;
  /** Rules pages use the wider column (--content-max-wide). */
  wide?: boolean;
  /** Gallery/guestbook pages use the widest column (--content-max-gallery). */
  gallery?: boolean;
  preloadCormorant?: boolean;
  preloadJost?: boolean;
}

const {
  title,
  lang,
  path,
  heading,
  description,
  wide = false,
  gallery = false,
  preloadCormorant = true,
  preloadJost = false,
} = Astro.props;
---

<Base
  title={title}
  lang={lang}
  path={path}
  description={description}
  preloadCormorant={preloadCormorant}
  preloadJost={preloadJost}
>
  <section
    class:list={[
      "content-section",
      wide && "content-section--wide",
      gallery && "content-section--gallery",
    ]}
  >
    <div class="section-head">
      <h1 class="page-heading">
        <span class="heading-gradient-text">{heading}</span>
      </h1>
    </div>
    <slot />
    <OrnamentDivider />
  </section>
</Base>

---
import type { ImageMetadata } from 'astro';
import { Image, getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { ICON_LAYOUT_PX } from '../data/layout';
import type { Lang } from '../data/nav';

interface Props {
  title: string;
  lang: Lang;
  path: string;
  heading: string;
  icon?: ImageMetadata;
}

const { title, lang, path, heading, icon } = Astro.props;

const lcpPreload = icon
  ? (await getImage({ src: icon, width: ICON_LAYOUT_PX * 2, format: 'webp' })).src
  : undefined;
---

<Base title={title} lang={lang} path={path} lcpPreload={lcpPreload}>
  <section class="mx-auto flex w-full max-w-[45rem] flex-col items-center gap-7 px-6 py-14">
    <h2 class="page-heading">{heading}</h2>
    {icon && (
      <Image
        src={icon}
        alt=""
        width={ICON_LAYOUT_PX}
        height={ICON_LAYOUT_PX}
        densities={[1, 2]}
        sizes={`${ICON_LAYOUT_PX}px`}
        loading="eager"
        fetchpriority="high"
        class="w-56 max-w-full"
      />
    )}
    <slot />
  </section>
</Base>

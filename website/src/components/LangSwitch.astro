---
import type { Lang } from "../data/nav";
import { langSwitchLabels } from "../data/ui";

interface Props {
  lang: Lang;
  altDe: string;
  altEn: string;
}

const { lang, altDe, altEn } = Astro.props;

const target = lang === "de" ? altEn : altDe;
const { title, altLabel } = langSwitchLabels[lang];
---

<a
  href={target}
  data-astro-prefetch
  aria-label={title}
  title={altLabel}
  class="header-chip header-chip--lang"
>
  {
    lang === "de" ? (
      <svg viewBox="0 0 60 30" aria-hidden="true" preserveAspectRatio="none">
        <rect width="60" height="30" fill="#012169" />
        <path d="M0,0 60,30 M60,0 0,30" stroke="#fff" stroke-width="6" />
        <path d="M0,0 60,30 M60,0 0,30" stroke="#c8102e" stroke-width="3" />
        <path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10" />
        <path d="M30,0 v30 M0,15 h60" stroke="#c8102e" stroke-width="6" />
      </svg>
    ) : (
      <svg viewBox="0 0 5 3" aria-hidden="true" preserveAspectRatio="none">
        <rect width="5" height="1" fill="#000" />
        <rect y="1" width="5" height="1" fill="#dd0000" />
        <rect y="2" width="5" height="1" fill="#ffce00" />
      </svg>
    )
  }
</a>

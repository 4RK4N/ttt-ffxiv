---
import { Image, getImage } from "astro:assets";
import Base from "../layouts/Base.astro";
import Timer from "./Timer.astro";
import DiscordButton from "./DiscordButton.astro";
import {
  HERO_CIRCLE_PX,
  HERO_REM,
  remScaledSizes,
  remScaledWidths,
} from "../data/layout";
import type { Lang } from "../data/nav";
import { homeCircle } from "../data/images";

interface Props {
  title: string;
  lang: Lang;
  path: string;
  tagline: string;
}

const { title, lang, path, tagline } = Astro.props;

const EVENT_TIMESTAMP = 1783188000;
const heroSizes = remScaledSizes(HERO_REM);
const heroWidths = remScaledWidths(HERO_REM);
const lcpPreload = {
  srcset: (
    await Promise.all(
      heroWidths.map((w) =>
        getImage({ src: homeCircle, width: w, format: "webp" }),
      ),
    )
  )
    .map((img, i) => `${img.src} ${heroWidths[i]}w`)
    .join(", "),
  sizes: heroSizes,
};
---

<Base title={title} lang={lang} path={path} heroLcp lcpPreload={lcpPreload}>
  <section
    class="mx-auto flex w-full max-w-[45rem] flex-col items-center gap-7 px-6 py-14"
  >
    <Image
      src={homeCircle}
      alt=""
      width={HERO_CIRCLE_PX}
      height={HERO_CIRCLE_PX}
      widths={heroWidths}
      sizes={heroSizes}
      loading="eager"
      fetchpriority="high"
      class="w-72 max-w-full"
    />
    <h1 class="page-heading">Tiny Temptation Tubs</h1>
    <p class="subtitle-text">Event Timer</p>
    <Timer lang={lang} timestamp={EVENT_TIMESTAMP} />
    <p class="subtitle-text">{tagline}</p>
    <p class="subtitle-text">Light, Alpha, Lavender Beds, W2, P51</p>
    <DiscordButton href="https://discord.gg/JjWMxjAPBe" />
  </section>
</Base>

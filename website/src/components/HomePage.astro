---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Timer from "./Timer.astro";
import DiscordButton from "./DiscordButton.astro";
import {
  HERO_CIRCLE_PX,
  HERO_REM,
  remScaledSizes,
  remScaledWidths,
} from "../data/layout";
import { homeCopy } from "../data/home";
import { buildResponsivePreload } from "../data/preload";
import { DISCORD_TTT, EVENT_TIMESTAMP, SERVER_LINE } from "../data/site";
import type { Lang } from "../data/nav";
import { homeCircle } from "../data/images";

interface Props {
  title: string;
  lang: Lang;
  path: string;
}

const { title, lang, path } = Astro.props;

const copy = homeCopy[lang];
const heroSizes = remScaledSizes(HERO_REM);
const heroWidths = remScaledWidths(HERO_REM);
const lcpPreload = await buildResponsivePreload(
  homeCircle,
  heroWidths,
  heroSizes,
);
---

<Base title={title} lang={lang} path={path} heroLcp lcpPreload={lcpPreload}>
  <section class="content-section">
    <Image
      src={homeCircle}
      alt=""
      width={HERO_CIRCLE_PX}
      height={HERO_CIRCLE_PX}
      widths={heroWidths}
      sizes={heroSizes}
      loading="eager"
      fetchpriority="high"
      class="w-72 max-w-full"
    />
    <h1 class="page-heading">
      <span class="page-heading__text" data-text="Tiny Temptation Tubs"
        >Tiny Temptation Tubs</span
      >
    </h1>
    <h2>{copy.openingHeading}</h2>
    <Timer lang={lang} timestamp={EVENT_TIMESTAMP} />
    <p class="hand-text hand-text--home">
      {
        copy.introLines.map((line, i) => (
          <>
            {i > 0 && <br />}
            {line}
          </>
        ))
      }
    </p>
    <p class="subtitle-text">{SERVER_LINE}</p>
    <DiscordButton href={DISCORD_TTT} />
  </section>
</Base>

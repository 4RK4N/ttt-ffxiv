---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Timer from './Timer.astro';
import DiscordButton from './DiscordButton.astro';
import IntroPanel from './IntroPanel.astro';
import OrnamentDivider from './OrnamentDivider.astro';
import AddressPlaque from './AddressPlaque.astro';
import SectionHeading from './SectionHeading.astro';
import { HERO_LOGO_PX, HERO_REM, remScaledSizes, remScaledWidths } from '../data/layout';
import { homeCopy } from '../data/home';
import { buildResponsivePreload } from '../data/preload';
import { DISCORD_TTT, EVENT_TIMESTAMP } from '../data/site';
import { type Lang, siteName } from '../data/nav';
import { homeLogo } from '../data/images';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const copy = homeCopy[lang];
const heroSizes = remScaledSizes(HERO_REM);
const heroWidths = remScaledWidths(HERO_REM);
const lcpPreload = await buildResponsivePreload(homeLogo, heroWidths, heroSizes);
---

<Base title={copy.title} lang={lang} path={copy.path} heroLcp lcpPreload={lcpPreload}>
  <section class="content-section content-section--home">
    <div class="section-head section-head--compact">
      <Image
        src={homeLogo}
        alt=""
        width={HERO_LOGO_PX}
        widths={heroWidths}
        sizes={heroSizes}
        loading="eager"
        fetchpriority="high"
        class="hero-logo"
      />
      <h1 class="page-heading page-heading--home">
        <span class="heading-gradient-text">{siteName}</span>
      </h1>
      <OrnamentDivider />
      <SectionHeading>{copy.openingHeading}</SectionHeading>
      <Timer lang={lang} timestamp={EVENT_TIMESTAMP} />
    </div>
    <AddressPlaque lang={lang} />
    <IntroPanel narrow>
      {copy.introLines.map((line) => <p>{line}</p>)}
    </IntroPanel>
    <DiscordButton href={DISCORD_TTT} />
    <OrnamentDivider />
  </section>
</Base>

---
import { Image, getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Timer from './Timer.astro';
import DiscordButton from './DiscordButton.astro';
import { HERO_CIRCLE_PX } from '../data/layout';
import type { Lang } from '../data/nav';
import { homeCircle } from '../data/images';

interface Props {
  title: string;
  lang: Lang;
  path: string;
  tagline: string;
}

const { title, lang, path, tagline } = Astro.props;

const EVENT_TIMESTAMP = 1783188000;
const lcpSrc = (await getImage({ src: homeCircle, width: HERO_CIRCLE_PX * 2, format: 'webp' })).src;
---

<Base title={title} lang={lang} path={path} heroLcp lcpPreload={lcpSrc}>
  <section
    class="mx-auto flex w-full max-w-[45rem] flex-col items-center gap-7 px-6 py-14"
  >
    <Image
      src={homeCircle}
      alt=""
      width={HERO_CIRCLE_PX}
      height={HERO_CIRCLE_PX}
      densities={[1, 2]}
      sizes={`${HERO_CIRCLE_PX}px`}
      loading="eager"
      fetchpriority="high"
      class="w-72 max-w-full"
    />
    <h1
      class="bg-gradient-to-b from-[#FF5CBE] to-[#FC0000] bg-clip-text font-caveat text-[3.625em] font-bold leading-[1.2] text-transparent"
    >
      Tiny Temptation Tubs
    </h1>
    <p class="subtitle-text">Event Timer</p>
    <Timer lang={lang} timestamp={EVENT_TIMESTAMP} />
    <p class="subtitle-text">{tagline}</p>
    <p class="subtitle-text">Light, Alpha, Lavender Beds, W2, P51</p>
    <DiscordButton href="https://discord.gg/JjWMxjAPBe" />
  </section>
</Base>

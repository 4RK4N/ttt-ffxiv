---
import DiscordLogo from './DiscordLogo.astro';

interface Props {
  href: string;
  label?: string;
}

const { href, label = 'Discord' } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class="header-chip header-chip--discord"
>
  <DiscordLogo />
</a>

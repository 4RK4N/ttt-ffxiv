---
import type { Lang } from "../data/nav";

interface Props {
  lang: Lang;
  /** Unix timestamp (seconds) the countdown targets. */
  timestamp: number;
}

const { lang, timestamp } = Astro.props;

const labels =
  lang === "de"
    ? ["Tage", "Stunden", "Minuten", "Sekunden"]
    : ["Days", "Hours", "Minutes", "Seconds"];

const openMessage = lang === "de" ? "Wir haben geöffnet!" : "We're open!";

const units = [86_400_000, 3_600_000, 60_000, 1000];
const targetMs = timestamp * 1000;
const now = Date.now();
let remaining = Math.max(0, targetMs - now);
const initialDigits = units.map((unit) => {
  const value = Math.floor(remaining / unit);
  remaining -= value * unit;
  return String(value).padStart(2, "0");
});
const isOpen = targetMs <= now;
---

<div
  id="event-timer"
  data-timestamp={timestamp}
  data-open-message={openMessage}
  aria-live="polite"
  class="flex w-full max-w-[36rem] flex-col items-center"
>
  {
    isOpen ? (
      <p class="font-averia text-[1.5em] font-bold text-timer-digit">
        {openMessage}
      </p>
    ) : (
      <div class="flex w-full items-stretch justify-center font-averia font-bold">
        {labels.map((label, i) => (
          <>
            {i > 0 && (
              <div class="mx-4 w-px self-stretch bg-white/40 sm:mx-8" />
            )}
            <div class="flex flex-col items-center py-4">
              <span class="timer-digit-panel">
                <span data-digit class="timer-digit text-[2.5em] leading-none">
                  {initialDigits[i]}
                </span>
              </span>
              <span class="mt-3 text-[0.625rem] uppercase tracking-[0.225rem] text-white">
                {label}
              </span>
            </div>
          </>
        ))}
      </div>
    )
  }
</div>

<script>
  const timer = document.getElementById("event-timer")!;
  const target = Number(timer.dataset.timestamp) * 1000;
  const openMessage = timer.dataset.openMessage ?? "We're open!";
  const digits = timer.querySelectorAll("[data-digit]");
  const units = [86_400_000, 3_600_000, 60_000, 1000];

  function showOpen() {
    timer.innerHTML = `<p class="font-averia text-[1.5em] font-bold text-timer-digit">${openMessage}</p>`;
  }

  function tick() {
    let remaining = Math.max(0, target - Date.now());
    if (remaining === 0) {
      showOpen();
      return false;
    }
    units.forEach((unit, i) => {
      const value = Math.floor(remaining / unit);
      remaining -= value * unit;
      digits[i].textContent = String(value).padStart(2, "0");
    });
    return true;
  }

  if (digits.length) {
    const interval = setInterval(() => {
      if (!tick()) clearInterval(interval);
    }, 1000);
    document.addEventListener("astro:page-load", () => clearInterval(interval));
  }
</script>

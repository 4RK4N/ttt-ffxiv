---
import type { Lang } from "../data/nav";
import { splitRemainingMs } from "../data/countdown";

interface Props {
  lang: Lang;
  /** Unix timestamp (seconds) the countdown targets. */
  timestamp: number;
}

const { lang, timestamp } = Astro.props;

const labels =
  lang === "de"
    ? ["Tage", "Stunden", "Minuten", "Sekunden"]
    : ["Days", "Hours", "Minutes", "Seconds"];

const openMessage = lang === "de" ? "Wir haben geöffnet!" : "We're open!";

const targetMs = timestamp * 1000;
const initialDigits = splitRemainingMs(targetMs - Date.now());
const isOpen = targetMs <= Date.now();
---

<div
  id="event-timer"
  data-timestamp={timestamp}
  data-open-message={openMessage}
  aria-live="polite"
  class="flex w-full max-w-full flex-col items-center"
>
  {
    isOpen ? (
      <p class="timer-open">{openMessage}</p>
    ) : (
      <div class="timer-row">
        {labels.map((label, i) => (
          <div class="timer-unit">
            <span data-digit class="timer-digit">
              {initialDigits[i]}
            </span>
            <span class="timer-label">{label}</span>
          </div>
        ))}
      </div>
    )
  }
</div>

<script>
  import { splitRemainingMs } from "../data/countdown";

  let interval: ReturnType<typeof setInterval> | undefined;

  function initTimer() {
    if (interval) {
      clearInterval(interval);
      interval = undefined;
    }

    const timer = document.getElementById(
      "event-timer",
    ) as HTMLDivElement | null;
    if (!timer) return;

    const target = Number(timer.dataset.timestamp) * 1000;
    const openMessage = timer.dataset.openMessage ?? "We're open!";
    const digits = timer.querySelectorAll<HTMLSpanElement>("[data-digit]");

    function showOpen() {
      timer!.replaceChildren();
      const paragraph = document.createElement("p");
      paragraph.className = "timer-open";
      paragraph.textContent = openMessage;
      timer!.append(paragraph);
    }

    function tick() {
      const remaining = target - Date.now();
      if (remaining <= 0) {
        showOpen();
        return false;
      }
      splitRemainingMs(remaining).forEach((digit, i) => {
        digits[i].textContent = digit;
      });
      return true;
    }

    if (!digits.length) {
      if (target <= Date.now()) showOpen();
      return;
    }

    tick();
    interval = setInterval(() => {
      if (!tick()) {
        clearInterval(interval);
        interval = undefined;
      }
    }, 1000);
  }

  document.addEventListener("astro:page-load", initTimer);
</script>

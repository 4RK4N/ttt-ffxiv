---
import CloseIcon from "./CloseIcon.astro";
import type { Lang } from "../data/nav";
import { lightboxLabels } from "../data/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const labels = lightboxLabels[lang];
---

<div
  id="lightbox"
  class="lightbox hidden"
  role="dialog"
  aria-modal="true"
  aria-label={labels.dialog}
  data-zoom-in={labels.zoomIn}
  data-zoom-out={labels.zoomOut}
  hidden
>
  <button
    type="button"
    id="lightbox-close"
    class="lightbox__close"
    aria-label={labels.close}
  >
    <CloseIcon class="h-5 w-5" />
  </button>
  <button
    type="button"
    id="lightbox-prev"
    class="lightbox__btn lightbox__btn--prev"
    aria-label={labels.prev}
  >
    <svg
      viewBox="0 0 24 24"
      class="h-6 w-6 fill-none stroke-current stroke-2"
      aria-hidden="true"
    >
      <path d="M15 6l-6 6 6 6"></path>
    </svg>
  </button>
  <div id="lightbox-stage" class="lightbox__stage">
    <img
      id="lightbox-image"
      class="lightbox__image"
      alt=""
      title={labels.zoomIn}
      aria-label={labels.zoomIn}
    />
  </div>
  <button
    type="button"
    id="lightbox-next"
    class="lightbox__btn lightbox__btn--next"
    aria-label={labels.next}
  >
    <svg
      viewBox="0 0 24 24"
      class="h-6 w-6 fill-none stroke-current stroke-2"
      aria-hidden="true"
    >
      <path d="M9 6l6 6-6 6"></path>
    </svg>
  </button>
  <p id="lightbox-counter" class="lightbox__counter" aria-live="polite"></p>
</div>

<script>
  import { on, renewListenerScope } from "../lib/dom-listeners";

  let triggers: HTMLButtonElement[] = [];
  let current = 0;
  let lastFocus: HTMLButtonElement | null = null;
  let overlayAbort: AbortController | null = null;
  let zoomed = false;
  let fitSrc = "";
  const documentScope = new AbortController();

  function getElements() {
    return {
      overlay: document.getElementById("lightbox") as HTMLDivElement | null,
      stage: document.getElementById("lightbox-stage") as HTMLDivElement | null,
      img: document.getElementById("lightbox-image") as HTMLImageElement | null,
      counter: document.getElementById(
        "lightbox-counter",
      ) as HTMLParagraphElement | null,
      closeBtn: document.getElementById(
        "lightbox-close",
      ) as HTMLButtonElement | null,
      prevBtn: document.getElementById(
        "lightbox-prev",
      ) as HTMLButtonElement | null,
      nextBtn: document.getElementById(
        "lightbox-next",
      ) as HTMLButtonElement | null,
    };
  }

  function imageSrc(source: HTMLImageElement): string {
    const src = source.currentSrc || source.src;
    if (src) return src;

    const srcset = source.getAttribute("srcset");
    if (!srcset) return "";

    const largest = srcset
      .split(",")
      .map((entry) => entry.trim().split(/\s+/))
      .sort((a, b) => {
        const wA = parseInt(a[1] || "0", 10);
        const wB = parseInt(b[1] || "0", 10);
        return wB - wA;
      })[0]?.[0];

    return largest || "";
  }

  function setZoomUi(isZoomed: boolean) {
    const { overlay, img } = getElements();
    if (!overlay || !img) return;

    zoomed = isZoomed;
    img.classList.toggle("is-zoomed", isZoomed);
    overlay.classList.toggle("is-zoomed", isZoomed);

    const label = isZoomed
      ? (overlay.dataset.zoomOut ?? "Zoom out")
      : (overlay.dataset.zoomIn ?? "Zoom in");
    img.title = label;
    img.setAttribute("aria-label", label);
  }

  function centerStageScroll() {
    const { stage } = getElements();
    if (!stage) return;

    stage.scrollLeft = (stage.scrollWidth - stage.clientWidth) / 2;
    stage.scrollTop = (stage.scrollHeight - stage.clientHeight) / 2;
  }

  function centerStageScrollAfterZoom(img: HTMLImageElement) {
    const center = () => {
      requestAnimationFrame(() => {
        requestAnimationFrame(centerStageScroll);
      });
    };

    if (img.complete && img.naturalWidth > 0) {
      center();
      return;
    }

    img.addEventListener("load", center, { once: true });
    if (img.decode) {
      img.decode().then(center).catch(center);
    }
  }

  function resetZoom() {
    const { stage, img } = getElements();
    if (!img) return;

    if (zoomed && fitSrc) {
      img.src = fitSrc;
    }

    setZoomUi(false);
    stage?.scrollTo(0, 0);
  }

  function hide() {
    const { overlay, img } = getElements();
    if (!overlay || !img) return;

    resetZoom();
    overlay.classList.add("hidden");
    overlay.hidden = true;
    document.body.classList.remove("overflow-hidden");
    img.src = "";
    fitSrc = "";
    lastFocus?.focus();
  }

  function show(index: number) {
    if (!triggers.length) return;

    const { overlay, img, counter, closeBtn } = getElements();
    if (!overlay || !img || !counter || !closeBtn) return;

    resetZoom();

    current = (index + triggers.length) % triggers.length;
    const trigger = triggers[current];
    const source = trigger.querySelector<HTMLImageElement>("img");
    if (!source) return;

    const src = imageSrc(source);
    if (!src) return;

    fitSrc = src;
    img.src = src;
    img.alt = source.alt;
    counter.textContent = `${current + 1} / ${triggers.length}`;
    overlay.classList.remove("hidden");
    overlay.hidden = false;
    document.body.classList.add("overflow-hidden");
    closeBtn.focus();
  }

  function onImageClick(e: Event) {
    e.stopPropagation();

    const { stage, img } = getElements();
    if (!img) return;

    const trigger = triggers[current];
    const fullSrc = trigger?.dataset.fullSrc;

    if (!zoomed) {
      const srcChanged = Boolean(fullSrc && img.src !== fullSrc);
      if (srcChanged && fullSrc) {
        img.src = fullSrc;
      }
      setZoomUi(true);
      if (srcChanged) {
        img.addEventListener("load", () => centerStageScrollAfterZoom(img), {
          once: true,
        });
      } else {
        centerStageScrollAfterZoom(img);
      }
      return;
    }

    if (fitSrc) {
      img.src = fitSrc;
    }
    setZoomUi(false);
    stage?.scrollTo(0, 0);
  }

  function onTriggerClick(e: Event) {
    const trigger = e.currentTarget as HTMLButtonElement;
    lastFocus = trigger;
    const index = triggers.indexOf(trigger);
    if (index >= 0) show(index);
  }

  function resetLightboxOnNavigation() {
    document.body.classList.remove("overflow-hidden");
    const { overlay, img } = getElements();
    if (!overlay) return;

    zoomed = false;
    fitSrc = "";
    overlay.classList.remove("is-zoomed");
    overlay.classList.add("hidden");
    overlay.hidden = true;
    if (img) {
      img.classList.remove("is-zoomed");
      img.src = "";
    }
  }

  function setupLightbox() {
    const els = getElements();
    if (
      !els.overlay ||
      !els.stage ||
      !els.img ||
      !els.counter ||
      !els.closeBtn ||
      !els.prevBtn ||
      !els.nextBtn
    ) {
      return;
    }

    resetLightboxOnNavigation();

    overlayAbort = renewListenerScope(overlayAbort);
    const { signal } = overlayAbort;

    triggers = [
      ...document.querySelectorAll<HTMLButtonElement>(".lightbox-trigger"),
    ];
    triggers.forEach((trigger) => {
      on(trigger, "click", onTriggerClick, signal);
    });

    on(els.closeBtn, "click", hide, signal);
    on(els.prevBtn, "click", () => show(current - 1), signal);
    on(els.nextBtn, "click", () => show(current + 1), signal);
    on(els.img, "click", onImageClick, signal);

    on(
      els.overlay,
      "click",
      (e) => {
        if (e.target === els.overlay) hide();
      },
      signal,
    );

    on(
      els.stage,
      "click",
      (e) => {
        if (e.target === els.stage) hide();
      },
      signal,
    );
  }

  on(
    document,
    "keydown",
    (e) => {
      if (!(e instanceof KeyboardEvent)) return;
      const { overlay } = getElements();
      if (!overlay || overlay.hidden) return;

      if (e.key === "Escape") hide();
      else if (e.key === "ArrowLeft") show(current - 1);
      else if (e.key === "ArrowRight") show(current + 1);
    },
    documentScope.signal,
  );

  document.addEventListener("astro:before-swap", resetLightboxOnNavigation);
  document.addEventListener("astro:page-load", setupLightbox);
  setupLightbox();
</script>

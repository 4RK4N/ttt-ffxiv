---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  width: number;
  sizes: string;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const { src, width, sizes, class: className, loading = 'lazy' } = Astro.props;
---

<Image
  src={src}
  alt=""
  width={width}
  densities={[1, 2]}
  sizes={sizes}
  loading={loading}
  class={className}
/>

---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  width: number;
  sizes: string;
  widths?: number[];
  class?: string;
  loading?: "lazy" | "eager";
  alt?: string;
  lightbox?: boolean;
}

const {
  src,
  width,
  sizes,
  widths,
  class: className,
  loading = "lazy",
  alt = "",
  lightbox = false,
} = Astro.props;
---

{
  lightbox && alt ? (
    <button
      type="button"
      class:list={[
        "image-frame lightbox-trigger mx-auto max-w-full cursor-pointer p-0",
        className,
      ]}
      aria-label={alt}
    >
      <Image
        src={src}
        alt={alt}
        width={width}
        {...(widths ? { widths } : { densities: [1, 2] })}
        sizes={sizes}
        loading={loading}
        class="block h-auto w-full"
      />
    </button>
  ) : (
    <div class:list={["image-frame mx-auto max-w-full", className]}>
      <Image
        src={src}
        alt={alt}
        width={width}
        {...(widths ? { widths } : { densities: [1, 2] })}
        sizes={sizes}
        loading={loading}
        class="block h-auto w-full"
      />
    </div>
  )
}

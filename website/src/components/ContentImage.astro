---
import type { ImageMetadata } from "astro";
import { getImage, Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  width: number;
  sizes: string;
  widths?: number[];
  class?: string;
  imageClass?: string;
  loading?: "lazy" | "eager";
  alt?: string;
  /** Open in site lightbox with zoom. Default true when alt is set. */
  lightbox?: boolean;
  /** Copper-framed layout for menu or event poster. */
  featured?: "menu" | "event";
}

const {
  src,
  width,
  sizes,
  widths,
  class: className,
  imageClass,
  loading = "lazy",
  alt = "",
  lightbox = true,
  featured,
} = Astro.props;

const useLightbox = lightbox && alt.trim().length > 0;

const frameClass =
  featured === "menu"
    ? "image-frame--featured image-frame--menu"
    : featured === "event"
      ? "image-frame--featured image-frame--event"
      : undefined;

const fullSrc = useLightbox
  ? (await getImage({ src, width: src.width, format: "webp" })).src
  : undefined;

const widthProps = widths ? { widths } : { densities: [1, 2] };
---

{
  useLightbox ? (
    <button
      type="button"
      class:list={[
        "image-frame lightbox-trigger mx-auto max-w-full cursor-pointer p-0",
        frameClass,
        className,
      ]}
      aria-label={alt}
      data-full-src={fullSrc}
    >
      <Image
        src={src}
        alt={alt}
        width={width}
        {...widthProps}
        sizes={sizes}
        loading={loading}
        class:list={["block h-auto w-full", imageClass]}
      />
    </button>
  ) : (
    <div class:list={["image-frame mx-auto max-w-full", frameClass, className]}>
      <Image
        src={src}
        alt={alt}
        width={width}
        {...widthProps}
        sizes={sizes}
        loading={loading}
        class:list={["block h-auto w-full", imageClass]}
      />
    </div>
  )
}

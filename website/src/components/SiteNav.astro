---
import NavDropdown from "./NavDropdown.astro";
import type { SiteMenu } from "../data/nav";

interface Props {
  menu: SiteMenu;
  currentPath: string;
  variant: "desktop" | "mobile";
  ariaLabel: string;
  id?: string;
  class?: string;
}

const {
  menu,
  currentPath,
  variant,
  ariaLabel,
  id,
  class: className,
} = Astro.props;

const isDesktop = variant === "desktop";
const isActive = (itemPath: string) => itemPath === currentPath;
const isCommunityActive = menu.community.items.some((item) =>
  isActive(item.path),
);
---

<nav id={id} class:list={[className]} aria-label={ariaLabel}>
  <ul
    class:list={[
      isDesktop && "flex flex-wrap items-center justify-center gap-x-4 gap-y-1",
    ]}
  >
    {
      menu.primary.map((item) => (
        <li class:list={[!isDesktop && "border-b border-bar-border/50"]}>
          <a
            href={item.path}
            data-astro-prefetch
            class:list={[
              "nav-link",
              isDesktop ? "" : "block px-1 py-2.5",
              isActive(item.path) && "nav-link--active",
              !isActive(item.path) && "text-bar-text",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))
    }
    <NavDropdown
      label={menu.community.label}
      items={menu.community.items}
      currentPath={currentPath}
      isGroupActive={isCommunityActive}
      variant={isDesktop ? "bar" : "drawer"}
    />
  </ul>
</nav>

---
import NavDropdown from "./NavDropdown.astro";
import { isNavPathActive, type NavItem, type SiteMenu } from "../data/nav";

interface Props {
  menu: SiteMenu;
  currentPath: string;
  variant: "desktop" | "mobile";
  ariaLabel: string;
  id?: string;
  class?: string;
}

const {
  menu,
  currentPath,
  variant,
  ariaLabel,
  id,
  class: className,
} = Astro.props;

const isDesktop = variant === "desktop";
const isActive = (itemPath: string) => isNavPathActive(itemPath, currentPath);
const isGroupActive = (items: NavItem[]) =>
  items.some((item) => isActive(item.path));
const isPicsActive = isGroupActive(menu.pics.items);
const isTeamActive = isGroupActive(menu.team.items);

const navLinkClass = (itemPath: string) => [
  "nav-link",
  isDesktop ? "" : "block px-1 py-2.5",
  isActive(itemPath) && "nav-link--active",
];

const navItemClass = !isDesktop ? "border-b border-bar-border" : undefined;
---

<nav id={id} class:list={[className]} aria-label={ariaLabel}>
  <ul
    class:list={[
      isDesktop && "site-nav-list flex flex-nowrap items-center justify-center",
    ]}
  >
    {
      menu.primaryLead.map((item) => (
        <li class:list={[navItemClass]}>
          <a
            href={item.path}
            data-astro-prefetch
            class:list={navLinkClass(item.path)}
          >
            {item.label}
          </a>
        </li>
      ))
    }
    <NavDropdown
      label={menu.pics.label}
      items={menu.pics.items}
      currentPath={currentPath}
      isGroupActive={isPicsActive}
      variant={isDesktop ? "bar" : "drawer"}
    />
    {
      menu.primaryTrail.map((item) => (
        <li class:list={[navItemClass]}>
          <a
            href={item.path}
            data-astro-prefetch
            class:list={navLinkClass(item.path)}
          >
            {item.label}
          </a>
        </li>
      ))
    }
    <NavDropdown
      label={menu.team.label}
      items={menu.team.items}
      currentPath={currentPath}
      isGroupActive={isTeamActive}
      variant={isDesktop ? "bar" : "drawer"}
    />
  </ul>
</nav>

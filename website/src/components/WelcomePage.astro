---
import Base from "../layouts/Base.astro";
import { navItems, type Lang } from "../data/nav";

interface Props {
  title: string;
  lang: Lang;
  path: string;
  heading: string;
  /** Button labels, in the same order as the nav items. */
  buttonLabels: string[];
}

const { title, lang, path, heading, buttonLabels } = Astro.props;

const buttons = navItems[lang].map((item, i) => ({
  href: item.path,
  label: buttonLabels[i] ?? item.label,
}));
---

<Base title={title} lang={lang} path={path}>
  <section
    class="mx-auto flex w-full max-w-[45rem] flex-col items-center gap-7 px-6 py-14"
  >
    <p
      class="font-caveat text-[2.375em] font-bold leading-[1.2] text-black/70 [text-shadow:0.088rem_0.088rem_0.125rem_#B31919]"
    >
      {heading}
    </p>
    <div
      class="hand-text flex flex-col gap-6 text-[1.875em] leading-[1.75] tracking-[0.2rem] text-black/70 [text-shadow:0.088rem_0.088rem_0.125rem_#F50707]"
    >
      <slot />
    </div>
    <ul class="flex flex-wrap justify-center gap-3">
      {
        buttons.map((btn) => (
          <li>
            <a
              href={btn.href}
              role="button"
              class="inline-block h-16 rounded border border-[#050505] bg-[#FAA7E8] bg-gradient-to-t from-[#A32C2C] to-[rgba(250,167,232,0.012)] px-8 font-averia text-[0.75em] font-bold uppercase leading-[calc(4rem-2px)] tracking-[0.25rem] text-black shadow-[-0.335rem_0.372rem_0.5rem_0_#000000] transition-colors hover:bg-[#ffc2f2]"
            >
              {btn.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

---
import type { ImageMetadata } from "astro";
import { getImage, Image } from "astro:assets";
import {
  LANDSCAPE_GALLERY_SIZES,
  LANDSCAPE_GALLERY_SIZES_WIDE,
  PORTRAIT_GALLERY_SIZES,
  PORTRAIT_GALLERY_SIZES_WIDE,
  landscapeGalleryWidths,
  portraitGalleryWidths,
} from "../data/layout";

interface Props {
  images: ImageMetadata[];
  aspect?: "portrait" | "landscape";
  cols?: 2;
  class?: string;
  /** Use wider column sizes for gallery/guestbook pages. */
  wide?: boolean;
  /** Enable click-to-expand lightbox. Default true. */
  lightbox?: boolean;
  /** Optional alt text prefix for accessibility. */
  altPrefix?: string;
}

const {
  images,
  aspect = "landscape",
  cols,
  class: className,
  wide = false,
  lightbox = true,
  altPrefix = "Screenshot",
} = Astro.props;

const colsClass = cols
  ? "grid-cols-2"
  : aspect === "portrait"
    ? "grid-cols-2 sm:grid-cols-3 lg:grid-cols-5"
    : "grid-cols-1 sm:grid-cols-2";

const imageSizes = wide
  ? aspect === "portrait"
    ? PORTRAIT_GALLERY_SIZES_WIDE
    : LANDSCAPE_GALLERY_SIZES_WIDE
  : aspect === "portrait"
    ? PORTRAIT_GALLERY_SIZES
    : LANDSCAPE_GALLERY_SIZES;

const imageWidths =
  aspect === "portrait" ? portraitGalleryWidths() : landscapeGalleryWidths();

const fullSrcs = lightbox
  ? await Promise.all(
      images.map(
        async (src) =>
          (await getImage({ src, width: src.width, format: "webp" })).src,
      ),
    )
  : [];
---

<div
  class:list={["grid w-full gallery-grid", colsClass, className]}
  data-lightbox-group={lightbox ? "" : undefined}
>
  {
    images.map((src, index) => {
      const alt = `${altPrefix} ${index + 1}`;
      const imageEl = (
        <Image
          src={src}
          alt={alt}
          width={src.width}
          height={src.height}
          widths={imageWidths}
          sizes={imageSizes}
          loading="lazy"
          class="block h-auto w-full"
        />
      );

      return lightbox ? (
        <button
          type="button"
          class="image-frame lightbox-trigger cursor-pointer p-0"
          data-lightbox-index={index}
          data-full-src={fullSrcs[index]}
          aria-label={alt}
        >
          {imageEl}
        </button>
      ) : (
        <div class="image-frame">{imageEl}</div>
      );
    })
  }
</div>

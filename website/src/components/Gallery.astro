---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import {
  CONTENT_COLUMN_PX,
  LANDSCAPE_CELL_PX,
  PORTRAIT_CELL_LG_PX,
  PORTRAIT_CELL_MD_PX,
} from '../data/layout';

interface Props {
  images: ImageMetadata[];
  aspect?: 'portrait' | 'landscape' | 'square';
  cols?: 2 | 3;
  class?: string;
}

const { images, aspect = 'landscape', cols, class: className } = Astro.props;

const aspectClass = {
  portrait: 'aspect-[2/3]',
  landscape: 'aspect-[16/9]',
  square: 'aspect-square',
}[aspect];

const colsClass = cols
  ? { 2: 'grid-cols-2', 3: 'grid-cols-3' }[cols]
  : aspect === 'portrait'
    ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-5'
    : 'grid-cols-1 sm:grid-cols-2';

const imageSizes =
  aspect === 'portrait'
    ? `(max-width: 640px) 45vw, (max-width: 1024px) ${PORTRAIT_CELL_MD_PX}px, ${PORTRAIT_CELL_LG_PX}px`
    : `(max-width: 640px) calc(100vw - 3rem), ${LANDSCAPE_CELL_PX}px`;

const imageWidths =
  aspect === 'portrait'
    ? [
        PORTRAIT_CELL_LG_PX,
        PORTRAIT_CELL_LG_PX * 2,
        PORTRAIT_CELL_MD_PX,
        PORTRAIT_CELL_MD_PX * 2,
      ]
    : [LANDSCAPE_CELL_PX, LANDSCAPE_CELL_PX * 2, CONTENT_COLUMN_PX, CONTENT_COLUMN_PX * 2];

const imageWidth =
  aspect === 'portrait' || aspect === 'square' ? PORTRAIT_CELL_LG_PX : LANDSCAPE_CELL_PX;

const imageHeight =
  aspect === 'portrait'
    ? Math.round((PORTRAIT_CELL_LG_PX * 3) / 2)
    : aspect === 'square'
      ? PORTRAIT_CELL_LG_PX
      : Math.round((LANDSCAPE_CELL_PX * 9) / 16);
---

<div class:list={['grid w-full gap-3', colsClass, className]}>
  {images.map((src) => (
    <Image
      src={src}
      alt=""
      width={imageWidth}
      height={imageHeight}
      widths={imageWidths}
      sizes={imageSizes}
      loading="lazy"
      class:list={['h-full w-full rounded-md object-cover', aspectClass]}
    />
  ))}
</div>

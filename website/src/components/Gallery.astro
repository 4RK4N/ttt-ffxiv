---
interface Props {
  images: string[];
  /** Thumbnail shape; matches the dominant aspect ratio of the set. */
  aspect?: 'portrait' | 'landscape' | 'square';
  /** Fixed column count; defaults to a responsive layout based on aspect. */
  cols?: 2 | 3;
  class?: string;
}

const { images, aspect = 'landscape', cols, class: className } = Astro.props;

const aspectClass = {
  portrait: 'aspect-[2/3]',
  landscape: 'aspect-[16/9]',
  square: 'aspect-square',
}[aspect];

// Portrait sets sit side by side; landscape sets stack wider.
const colsClass = cols
  ? { 2: 'grid-cols-2', 3: 'grid-cols-3' }[cols]
  : aspect === 'portrait'
    ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-5'
    : 'grid-cols-1 sm:grid-cols-2';
---

<div class:list={['grid w-full gap-3', colsClass, className]}>
  {images.map((src) => (
    <img
      src={src}
      alt=""
      loading="lazy"
      class:list={['h-full w-full rounded-md object-cover', aspectClass]}
    />
  ))}
</div>

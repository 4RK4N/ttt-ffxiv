---
import type { ImageMetadata } from 'astro';
import { getImage, Image } from 'astro:assets';
import {
  GALLERY_GRID_SIZES,
  GALLERY_GRID_SIZES_WIDE,
  galleryGridWidths,
  GALLERY_GRID_3COL_SIZES,
  GALLERY_GRID_3COL_SIZES_WIDE,
  GALLERY_GRID_DENSE_SIZES,
  GALLERY_GRID_DENSE_SIZES_WIDE,
  galleryGridDenseWidths,
} from '../data/layout';

interface Props {
  images: ImageMetadata[];
  /** Grid columns: default 2 on sm+, 3 for staff-style grids, or 5 for denser layouts. */
  cols?: 2 | 3 | 5;
  class?: string;
  /** Use wider column sizes for gallery/guestbook pages. */
  wide?: boolean;
  /** Enable click-to-expand lightbox. Default true. */
  lightbox?: boolean;
  /** Optional alt text prefix for accessibility. */
  altPrefix?: string;
}

const {
  images,
  cols,
  class: className,
  wide = false,
  lightbox = true,
  altPrefix = 'Screenshot',
} = Astro.props;

const colsClass =
  cols === 2
    ? 'grid-cols-2'
    : cols === 3
      ? 'grid-cols-2 sm:grid-cols-3'
      : cols === 5
        ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-5'
        : 'grid-cols-1 sm:grid-cols-2';

const dense = cols === 5;
const threeCol = cols === 3;
const imageSizes = wide
  ? dense
    ? GALLERY_GRID_DENSE_SIZES_WIDE
    : threeCol
      ? GALLERY_GRID_3COL_SIZES_WIDE
      : GALLERY_GRID_SIZES_WIDE
  : dense
    ? GALLERY_GRID_DENSE_SIZES
    : threeCol
      ? GALLERY_GRID_3COL_SIZES
      : GALLERY_GRID_SIZES;
const imageWidths = dense ? galleryGridDenseWidths() : galleryGridWidths();

const fullSrcs = lightbox
  ? await Promise.all(
      images.map(async (src) => (await getImage({ src, width: src.width, format: 'webp' })).src)
    )
  : [];
---

<div class:list={['grid w-full gallery-grid', colsClass, className]}>
  {
    images.map((src, index) => {
      const alt = `${altPrefix} ${index + 1}`;
      const imageEl = (
        <Image
          src={src}
          alt={alt}
          width={src.width}
          height={src.height}
          widths={imageWidths}
          sizes={imageSizes}
          loading="lazy"
          class="block h-auto w-full"
        />
      );

      return lightbox ? (
        <button
          type="button"
          class="image-frame lightbox-trigger cursor-pointer p-0"
          data-full-src={fullSrcs[index]}
          aria-label={alt}
        >
          {imageEl}
        </button>
      ) : (
        <div class="image-frame">{imageEl}</div>
      );
    })
  }
</div>

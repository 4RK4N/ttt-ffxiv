---
import ContentPage from './ContentPage.astro';
import ContentImage from './ContentImage.astro';
import Gallery from './Gallery.astro';
import SectionHeading from './SectionHeading.astro';
import {
  FEATURED_EVENT_IMAGE_PX,
  FEATURED_EVENT_REM,
  featuredEventImageSizes,
  remScaledWidths,
} from '../data/layout';
import { eventArchiveImages, resolveImage } from '../data/images';
import { eventsCopy, FEATURED_EVENT_IMAGE } from '../data/events';
import type { Lang } from '../data/nav';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = eventsCopy[lang];
---

<ContentPage title={copy.title} lang={lang} path={copy.path} heading={copy.heading} gallery>
  <ContentImage
    src={resolveImage(FEATURED_EVENT_IMAGE)}
    width={FEATURED_EVENT_IMAGE_PX}
    sizes={featuredEventImageSizes()}
    widths={remScaledWidths(FEATURED_EVENT_REM)}
    featured="event"
    class="w-full"
    alt={copy.featuredAlt}
  />
  <SectionHeading>{copy.archiveHeading}</SectionHeading>
  <Gallery wide cols={5} altPrefix={copy.photoAltPrefix} images={eventArchiveImages} />
</ContentPage>

---
import type { NavItem } from "../data/nav";

interface Props {
  label: string;
  items: NavItem[];
  currentPath: string;
  isGroupActive: boolean;
  variant?: "bar" | "drawer";
}

const {
  label,
  items,
  currentPath,
  isGroupActive,
  variant = "bar",
} = Astro.props;

const isDrawer = variant === "drawer";
const isActive = (itemPath: string) => itemPath === currentPath;
---

<li
  class:list={[
    "nav-dropdown",
    isDrawer
      ? "nav-dropdown--drawer border-b border-bar-border/50"
      : "relative",
  ]}
>
  <button
    type="button"
    class:list={[
      "nav-link nav-dropdown-trigger cursor-pointer gap-1 bg-transparent font-inherit",
      isDrawer && "block w-full px-1 py-2.5 text-left",
      isGroupActive ? "nav-link--active text-bar-accent" : "text-bar-text",
    ]}
    aria-haspopup="true"
    aria-expanded="false"
  >
    {label}
    <svg
      viewBox="0 0 12 8"
      class="h-2 w-3 shrink-0 fill-current transition-transform duration-200"
      aria-hidden="true"
    >
      <path d="M1 1l5 5 5-5"></path>
    </svg>
  </button>
  <ul
    class:list={[
      "nav-dropdown-menu",
      !isDrawer &&
        "site-bar absolute left-1/2 top-full z-50 mt-1 min-w-[10rem] -translate-x-1/2 rounded border py-1 shadow-lg",
    ]}
    role="menu"
  >
    {
      items.map((item) => (
        <li role="none">
          <a
            href={item.path}
            data-astro-prefetch
            role="menuitem"
            class:list={[
              "nav-link block px-4 py-2 text-left",
              isActive(item.path)
                ? "nav-link--active text-bar-accent"
                : "text-bar-text",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</li>

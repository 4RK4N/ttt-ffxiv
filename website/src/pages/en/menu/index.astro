---
import ContentPage from "../../../components/ContentPage.astro";
import ContentImage from "../../../components/ContentImage.astro";
import {
  GALLERY_CONTENT_COLUMN_SIZES,
  CONTENT_COLUMN_PX,
  contentColumnWidths,
} from "../../../data/layout";
import { pageImages } from "../../../data/images";
---

<ContentPage
  title="Menu | Tiny Temptation Tubs"
  lang="en"
  path="/en/menu/"
  heading="Menu"
  gallery
>
  <ContentImage
    src={pageImages.drinksMenu}
    width={CONTENT_COLUMN_PX}
    sizes={GALLERY_CONTENT_COLUMN_SIZES}
    widths={contentColumnWidths()}
    featured="menu"
    class="w-full"
    alt="Drinks menu at Tiny Temptation Tubs, served by Ralvus the bartender"
  />
</ContentPage>

---
import ContentPage from "../../../components/ContentPage.astro";
import Gallery from "../../../components/Gallery.astro";
import { resolveGalleryList } from "../../../data/images";
---

<ContentPage
  title="Guestbook | Tiny Temptation Tubs"
  lang="en"
  path="/en/guestbook/"
  heading="Guestbook"
  gallery
>
  <Fragment slot="intro">
    <p class="hand-text">
      Messages from our community — shared here as screenshots from our Discord.
    </p>
    <p class="hand-text">
      <em
        ><strong
          >They say words can remain… Leave a piece of yourself, a few thoughts
          or memories so your journey here never truly fades.</strong
        ></em
      >
    </p>
  </Fragment>
  <Gallery
    wide
    aspect="landscape"
    altPrefix="Guestbook message"
    images={resolveGalleryList([
      "gallery08/b04b2349.jpg",
      "gallery08/fb0b75e8.jpg",
      "gallery08/228b4f2a.jpg",
      "gallery08/ca8d23e8.jpg",
      "gallery08/ab7b15ef.jpg",
      "gallery08/4422e621.jpg",
      "gallery08/ca8cef1a.jpg",
      "gallery08/895a9878.jpg",
    ])}
  />
</ContentPage>

---
import ContentPage from "../../../../components/ContentPage.astro";
import StaffIntro from "../../../../components/StaffIntro.astro";
import Gallery from "../../../../components/Gallery.astro";
import {
  staffCopy,
  staffLandscape,
  staffPortraits,
} from "../../../../data/staff";

const copy = staffCopy.en;
---

<ContentPage
  title="Staff | Tiny Temptation Tubs"
  lang="en"
  path="/en/team/staff/"
  heading="Staff"
>
  <StaffIntro lang="en" />
  <Gallery cols={5} altPrefix={copy.altPrefix} images={staffPortraits} />
  <Gallery
    cols={2}
    altPrefix={copy.altPrefix}
    class="w-full"
    images={staffLandscape}
  />
</ContentPage>

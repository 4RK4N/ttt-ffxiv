---
import ContentPage from "../../../components/ContentPage.astro";
import IntroPanel from "../../../components/IntroPanel.astro";
import Gallery from "../../../components/Gallery.astro";
import { guestbookImages } from "../../../data/images";
---

<ContentPage
  title="Gästebuch | Tiny Temptation Tubs"
  lang="de"
  path="/de/gaestebuch/"
  heading="Gästebuch"
  gallery
>
  <IntroPanel gap={4}>
    <p>
      Nachrichten unserer Gäste aus dem Gästebuch unserer XIV-Location — hier
      als Screenshots festgehalten.
    </p>
    <p>
      <strong
        >Man sagt, Worte können bleiben… Hinterlasse ein Stück von dir, ein paar
        Gedanken oder Erinnerungen — damit deine Reise bei uns niemals ganz
        vergeht.</strong
      >
    </p>
  </IntroPanel>
  <Gallery wide altPrefix="Gästebuch-Nachricht" images={guestbookImages} />
</ContentPage>

---
import ContentPage from "../../../components/ContentPage.astro";
import Gallery from "../../../components/Gallery.astro";
import { resolveGalleryList } from "../../../data/images";
---

<ContentPage
  title="Gästebuch | Tiny Temptation Tubs"
  lang="de"
  path="/de/gaestebuch/"
  heading="Gästebuch"
  gallery
>
  <Fragment slot="intro">
    <p class="hand-text">
      Nachrichten aus unserer Community — hier als Screenshots aus unserem
      Discord geteilt.
    </p>
    <p class="hand-text">
      <em
        ><strong
          >Man sagt, Worte können bleiben… Hinterlasse ein Stück von dir, ein
          paar Gedanken oder Erinnerungen — damit deine Reise bei uns niemals
          ganz vergeht.</strong
        ></em
      >
    </p>
  </Fragment>
  <Gallery
    wide
    aspect="landscape"
    altPrefix="Gästebuch-Nachricht"
    images={resolveGalleryList([
      "gallery01/b04b2349.jpg",
      "gallery01/fb0b75e8.jpg",
      "gallery01/228b4f2a.jpg",
      "gallery01/ca8d23e8.jpg",
      "gallery01/ab7b15ef.jpg",
      "gallery01/4422e621.jpg",
      "gallery01/ca8cef1a.jpg",
      "gallery01/895a9878.jpg",
    ])}
  />
</ContentPage>

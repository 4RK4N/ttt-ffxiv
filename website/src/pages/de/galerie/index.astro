---
import ContentPage from "../../../components/ContentPage.astro";
import ContentImage from "../../../components/ContentImage.astro";
import Gallery from "../../../components/Gallery.astro";
import {
  CONTENT_COLUMN_SIZES,
  CONTENT_COLUMN_PX,
  contentColumnWidths,
} from "../../../data/layout";
import { pageIcons, resolveGalleryList } from "../../../data/images";
---

<ContentPage
  title="Galerie | Tiny Temptation Tubs"
  lang="de"
  path="/de/galerie/"
  heading="Galerie"
  icon={pageIcons.image06}
>
  <div class="hand-text flex flex-col gap-6">
    <p><em><strong>Ein Blick in unser Haus…</strong></em></p>
    <p>
      <em
        ><strong
          >Warme Räume, stille Ecken,<br /> sanftes Licht und Orte,<br /> an denen
          Erinnerungen entstehen.</strong
        ></em
      >
    </p>
  </div>
  <ContentImage
    src={pageIcons.image09}
    width={CONTENT_COLUMN_PX}
    sizes={CONTENT_COLUMN_SIZES}
    widths={contentColumnWidths()}
    class="w-full rounded-md"
  />
  <Gallery
    images={resolveGalleryList([
      "gallery23/9c352b69.jpg",
      "gallery23/fcd8f85d.jpg",
      "gallery23/81a2a56a.jpg",
    ])}
  />
  <Gallery
    images={resolveGalleryList([
      "gallery18/c2cde289.jpg",
      "gallery18/09600657.jpg",
      "gallery18/009cce14.jpg",
      "gallery18/736c6a9a.jpg",
      "gallery18/7b549343.jpg",
    ])}
  />
  <Gallery
    images={resolveGalleryList([
      "gallery19/d7414f9a.jpg",
      "gallery19/cac149e2.jpg",
      "gallery19/ac774d7a.jpg",
      "gallery19/068c47f1.jpg",
      "gallery19/eb706e6d.jpg",
      "gallery19/dfbe594f.jpg",
    ])}
  />
  <p class="section-heading">Zimmer 2</p>
  <Gallery
    images={resolveGalleryList([
      "gallery11/716cf24b.jpg",
      "gallery11/ab4e17c6.jpg",
      "gallery11/dddae266.jpg",
      "gallery11/f3f31675.jpg",
      "gallery11/88a002bb.jpg",
      "gallery11/3ec6e4af.jpg",
      "gallery11/03ac8647.jpg",
      "gallery11/e83b206b.jpg",
    ])}
  />
</ContentPage>

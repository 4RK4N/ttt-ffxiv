---
import ContentPage from '../../../components/ContentPage.astro';
import ContentImage from '../../../components/ContentImage.astro';
import Gallery from '../../../components/Gallery.astro';
import { CARD_IMAGE_PX, NARROW_CONTENT_BP_PX } from '../../../data/layout';
import { pageIcons, resolveGalleryList } from '../../../data/images';
---

<ContentPage
  title="Events | Tiny Temptation Tubs"
  lang="de"
  path="/de/events/"
  heading="Events"
  icon={pageIcons.image14}
>
  <ContentImage
    src={pageIcons.image15}
    width={CARD_IMAGE_PX}
    sizes={`(max-width: ${NARROW_CONTENT_BP_PX}px) 100vw, ${CARD_IMAGE_PX}px`}
    class="w-full max-w-[24rem] rounded-md"
  />
  <p class="hand-text">★<em><strong>Archive</strong></em>★</p>
  <Gallery
    aspect="portrait"
    images={resolveGalleryList([
      'gallery13/b38bdd4c.jpg',
      'gallery13/895354f2.jpg',
      'gallery13/68509e48.jpg',
      'gallery13/33482412.jpg',
      'gallery13/f52a90b4.jpg',
    ])}
  />
</ContentPage>

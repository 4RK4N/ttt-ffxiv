---
import ContentPage from "../../../../components/ContentPage.astro";
import StaffIntro from "../../../../components/StaffIntro.astro";
import Gallery from "../../../../components/Gallery.astro";
import {
  staffCopy,
  staffLandscape,
  staffPortraits,
} from "../../../../data/staff";

const copy = staffCopy.de;
---

<ContentPage
  title="Staff | Tiny Temptation Tubs"
  lang="de"
  path="/de/team/staff/"
  heading="Staff"
  gallery
>
  <StaffIntro lang="de" />
  <Gallery wide cols={5} altPrefix={copy.altPrefix} images={staffPortraits} />
  <Gallery
    wide
    cols={2}
    altPrefix={copy.altPrefix}
    class="w-full"
    images={staffLandscape}
  />
</ContentPage>

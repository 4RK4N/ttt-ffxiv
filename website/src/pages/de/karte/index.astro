---
import ContentPage from "../../../components/ContentPage.astro";
import ContentImage from "../../../components/ContentImage.astro";
import {
  CONTENT_COLUMN_PX,
  CONTENT_COLUMN_SIZES,
  contentColumnWidths,
} from "../../../data/layout";
import { pageImages } from "../../../data/images";
---

<ContentPage
  title="Karte | Tiny Temptation Tubs"
  lang="de"
  path="/de/karte/"
  heading="Karte"
>
  <ContentImage
    src={pageImages.drinksMenu}
    width={CONTENT_COLUMN_PX}
    sizes={CONTENT_COLUMN_SIZES}
    widths={contentColumnWidths()}
    featured="menu"
    class="w-full"
    alt="Getränkekarte im Tiny Temptation Tubs, serviert von Ralvus dem Barkeeper"
  />
</ContentPage>

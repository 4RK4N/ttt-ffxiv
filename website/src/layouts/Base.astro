---
import "../styles/global.css";
import { Font, Image, getImage } from "astro:assets";
import {
  siteName,
  siteDescription,
  navItems,
  footerLinks,
  homePath,
  pathMap,
  type Lang,
} from "../data/nav";
import {
  headerLogoDisplayHeight,
  headerLogoDisplayPx,
  headerLogoSizes,
  headerLogoWidths,
} from "../data/layout";
import { SITE_URL } from "../data/site";
import { logo, bg } from "../data/images";

interface Props {
  title: string;
  lang: Lang;
  /** Site-absolute path of this page, e.g. "/de/regeln/" or "/de.html". */
  path: string;
  /** Overrides the language default for meta description and social previews. */
  description?: string;
  /** Home page: hero image is LCP; defer logo fetch priority. */
  heroLcp?: boolean;
  /** Responsive preload for the home hero image. */
  lcpPreload?: { srcset: string; sizes: string };
}

const { title, lang, path, description, heroLcp, lcpPreload } = Astro.props;

const metaDescription = description ?? siteDescription[lang];
const shareImage = `${SITE_URL}/assets/images/share.jpg`;

const nav = navItems[lang];
const legal = footerLinks[lang];
const alt = pathMap[path] ?? { de: "/de.html", en: "/" };
const canonical = SITE_URL + (path === "/" ? "" : path.replace(/\/$/, ""));

const bgOptimized = await getImage({ src: bg, width: 1920, format: "webp" });

const isActive = (itemPath: string) => itemPath === path;
---

<!doctype html>
<html lang={lang} style={`--page-bg-image: url(${bgOptimized.src})`}>
  <head>
    <title>{title}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={metaDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="440" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={shareImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png" />
    {
      lcpPreload && (
        <link
          rel="preload"
          as="image"
          imagesrcset={lcpPreload.srcset}
          imagesizes={lcpPreload.sizes}
          fetchpriority="high"
        />
      )
    }
    <Font cssVariable="--font-averia-face" preload />
    <Font cssVariable="--font-gochi-face" preload />
    <Font cssVariable="--font-caveat-face" preload />
  </head>

  <body class="pt-[68px]">
    <header
      class="fixed inset-x-0 top-0 z-50 flex h-[68px] items-center gap-4 border-b border-bar-border bg-bar-bg px-4 font-averia text-[15px] backdrop-blur-sm lg:px-6"
    >
      <a href={homePath[lang]} class="flex h-full shrink-0 items-center py-1.5">
        <Image
          src={logo}
          alt={siteName}
          width={headerLogoDisplayPx()}
          height={headerLogoDisplayHeight()}
          widths={headerLogoWidths()}
          sizes={headerLogoSizes()}
          loading="eager"
          fetchpriority={heroLcp || lcpPreload ? undefined : "high"}
          class="block h-full w-auto"
        />
      </a>

      <nav
        class="hidden flex-1 md:block"
        aria-label={lang === "de" ? "Hauptmenü" : "Main menu"}
      >
        <ul class="flex flex-wrap justify-center gap-x-4 gap-y-1">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.path}
                  data-astro-prefetch
                  class:list={[
                    "whitespace-nowrap px-0.5 py-1 transition-colors hover:text-bar-accent",
                    isActive(item.path) ? "text-bar-accent" : "text-bar-text",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="ml-auto flex items-center gap-2">
        <label for="lang-select" class="sr-only">Language</label>
        <select
          id="lang-select"
          aria-label="Language"
          data-de={alt.de}
          data-en={alt.en}
          class="cursor-pointer appearance-none rounded border border-bar-border bg-black/35 bg-[url('data:image/svg+xml,%3Csvg%20xmlns=%27http://www.w3.org/2000/svg%27%20width=%2712%27%20height=%278%27%20viewBox=%270%200%2012%208%27%3E%3Cpath%20fill=%27%23d4af78%27%20d=%27M1%201l5%205%205-5%27/%3E%3C/svg%3E')] bg-[right_0.5rem_center] bg-no-repeat py-1 pl-2.5 pr-7 text-[13px] text-bar-text"
        >
          <option value="de" selected={lang === "de"}>Deutsch</option>
          <option value="en" selected={lang === "en"}>English</option>
        </select>

        <button
          type="button"
          id="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-drawer"
          aria-label={lang === "de" ? "Menü" : "Menu"}
          class="flex h-9 w-9 cursor-pointer items-center justify-center rounded border border-bar-border bg-black/35 text-xl leading-none text-bar-text transition-colors hover:border-bar-accent hover:text-bar-accent md:hidden"
        >
          ☰
        </button>
      </div>
    </header>

    <nav
      id="mobile-drawer"
      aria-label={lang === "de" ? "Mobilmenü" : "Mobile menu"}
      class="fixed inset-x-0 top-[68px] z-40 hidden max-h-[calc(100vh-68px)] overflow-y-auto border-b border-bar-border bg-bar-bg px-4 pb-4 pt-3 text-left font-averia text-[15px] md:hidden!"
    >
      <ul>
        {
          nav.map((item) => (
            <li class="border-b border-bar-border/50 last:border-b-0">
              <a
                href={item.path}
                data-astro-prefetch
                class:list={[
                  "block px-1 py-2.5 transition-colors hover:text-bar-accent",
                  isActive(item.path) ? "text-bar-accent" : "text-bar-text",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer
      class="border-t border-bar-border px-4 py-4 text-center font-averia text-[13px] text-bar-text/70"
    >
      <nav aria-label={lang === "de" ? "Rechtliches" : "Legal"}>
        <a
          href={legal[0].path}
          data-astro-prefetch
          class="transition-colors hover:text-bar-accent"
        >
          {legal[0].label}
        </a>
        <span aria-hidden="true" class="px-1.5 text-bar-text/40">·</span>
        <a
          href={legal[1].path}
          data-astro-prefetch
          class="transition-colors hover:text-bar-accent"
        >
          {legal[1].label}
        </a>
      </nav>
    </footer>

    <script>
      const toggle = document.getElementById("menu-toggle")!;
      const drawer = document.getElementById("mobile-drawer")!;

      function setDrawer(open: boolean) {
        drawer.classList.toggle("hidden", !open);
        document.body.classList.toggle("overflow-hidden", open);
        toggle.setAttribute("aria-expanded", String(open));
      }

      toggle.addEventListener("click", () => {
        setDrawer(drawer.classList.contains("hidden"));
      });
      drawer.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).tagName === "A") setDrawer(false);
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setDrawer(false);
      });

      const langSelect = document.getElementById(
        "lang-select",
      ) as HTMLSelectElement;
      langSelect.addEventListener("change", () => {
        const target = langSelect.dataset[langSelect.value];
        if (target) window.location.href = target;
      });
    </script>
  </body>
</html>

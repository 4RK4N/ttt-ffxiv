---
import "../styles/global.css";
import { Font, Image, getImage } from "astro:assets";
import { ClientRouter, fade } from "astro:transitions";
import {
  siteName,
  siteDescription,
  siteMenu,
  footerLinks,
  homePath,
  pathMap,
  type Lang,
} from "../data/nav";
import {
  headerLogoDisplayHeight,
  headerLogoDisplayPx,
  headerLogoSizes,
  headerLogoWidths,
} from "../data/layout";
import { DISCORD_TTT, SITE_URL } from "../data/site";
import { logo, bg } from "../data/images";
import SiteNav from "../components/SiteNav.astro";
import DiscordIcon from "../components/DiscordIcon.astro";
import LangSwitch from "../components/LangSwitch.astro";
import Lightbox from "../components/Lightbox.astro";

interface Props {
  title: string;
  lang: Lang;
  /** Site-absolute path of this page, e.g. "/de/regeln/" or "/de.html". */
  path: string;
  /** Overrides the language default for meta description and social previews. */
  description?: string;
  /** Home page: hero image is LCP; defer logo fetch priority. */
  heroLcp?: boolean;
  /** Responsive preload for the home hero image. */
  lcpPreload?: { srcset: string; sizes: string };
  /** Preload Caveat (pages with h1 page-heading). Default true. */
  preloadCaveat?: boolean;
  /** Preload Gochi Hand (body copy). Default true. */
  preloadGochi?: boolean;
}

const {
  title,
  lang,
  path,
  description,
  heroLcp,
  lcpPreload,
  preloadCaveat = true,
  preloadGochi = true,
} = Astro.props;

const metaDescription = description ?? siteDescription[lang];
const shareImage = `${SITE_URL}/assets/images/share.jpg`;

const menu = siteMenu[lang];
const legal = footerLinks[lang];
const alt = pathMap[path] ?? { de: "/de.html", en: "/" };
const canonical = SITE_URL + (path === "/" ? "" : path.replace(/\/$/, ""));

const bgOptimized = await getImage({ src: bg, width: 1920, format: "webp" });

const skipLabel = lang === "de" ? "Zum Inhalt springen" : "Skip to content";
const mainMenuLabel = lang === "de" ? "Hauptmenü" : "Main menu";
const mobileMenuLabel = lang === "de" ? "Mobilmenü" : "Mobile menu";
---

<!doctype html>
<html lang={lang} style={`--page-bg-image: url(${bgOptimized.src})`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="440" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={shareImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png" />
    {
      lcpPreload && (
        <link
          rel="preload"
          as="image"
          imagesrcset={lcpPreload.srcset}
          imagesizes={lcpPreload.sizes}
          fetchpriority="high"
        />
      )
    }
    <Font cssVariable="--font-averia-face" preload />
    {preloadGochi && <Font cssVariable="--font-gochi-face" preload />}
    {preloadCaveat && <Font cssVariable="--font-caveat-face" preload />}
    <ClientRouter />
  </head>

  <body class="pt-[length:var(--header-height)]">
    <a href="#main-content" class="skip-link site-bar site-bar--header"
      >{skipLabel}</a
    >

    <header
      class="site-bar site-bar--header fixed inset-x-0 top-0 z-50 flex h-[length:var(--header-height)] items-center gap-4 px-4 font-averia text-[15px] lg:px-6"
    >
      <a href={homePath[lang]} class="flex h-full shrink-0 items-center py-1.5">
        <Image
          src={logo}
          alt={siteName}
          width={headerLogoDisplayPx()}
          height={headerLogoDisplayHeight()}
          widths={headerLogoWidths()}
          sizes={headerLogoSizes()}
          loading="eager"
          fetchpriority={heroLcp || lcpPreload ? undefined : "high"}
          class="block h-full w-auto"
        />
      </a>

      <SiteNav
        menu={menu}
        currentPath={path}
        variant="desktop"
        ariaLabel={mainMenuLabel}
        class="site-nav hidden flex-1 md:block"
      />

      <div class="ml-auto flex items-center gap-2">
        <LangSwitch lang={lang} altDe={alt.de} altEn={alt.en} />

        <DiscordIcon href={DISCORD_TTT} label="Discord" />

        <button
          type="button"
          id="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-drawer"
          aria-label={lang === "de" ? "Menü" : "Menu"}
          class="site-control flex h-9 w-9 cursor-pointer items-center justify-center hover:border-bar-accent hover:text-bar-accent md:hidden"
        >
          <svg
            id="menu-icon-open"
            viewBox="0 0 24 24"
            class="h-5 w-5 fill-none stroke-current stroke-2"
            aria-hidden="true"
          >
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
          <svg
            id="menu-icon-close"
            viewBox="0 0 24 24"
            class="hidden h-5 w-5 fill-none stroke-current stroke-2"
            aria-hidden="true"
          >
            <path d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
      </div>
    </header>

    <SiteNav
      id="mobile-drawer"
      menu={menu}
      currentPath={path}
      variant="mobile"
      ariaLabel={mobileMenuLabel}
      class="site-bar site-bar--header fixed inset-x-0 top-[length:var(--header-height)] z-40 hidden max-h-[calc(100vh-var(--header-height))] overflow-y-auto px-4 pb-4 pt-3 text-left font-averia text-[15px] md:hidden!"
    />

    <main id="main-content" transition:animate={fade({ duration: "0.2s" })}>
      <slot />
    </main>

    <footer
      class="site-bar site-bar--footer px-4 py-5 text-center font-averia text-[13px] text-bar-text/70"
    >
      <div class="section-divider mx-auto mb-4 max-w-md" aria-hidden="true">
      </div>
      <nav
        class="flex flex-wrap justify-center gap-x-3"
        aria-label={lang === "de" ? "Rechtliches" : "Legal"}
      >
        {
          legal.map((item) => (
            <a
              href={item.path}
              data-astro-prefetch
              class="transition-colors hover:text-bar-accent"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </footer>

    <Lightbox />

    <script>
      const toggle = document.getElementById("menu-toggle")!;
      const drawer = document.getElementById("mobile-drawer")!;
      const iconOpen = document.getElementById("menu-icon-open")!;
      const iconClose = document.getElementById("menu-icon-close")!;

      function closeAllDropdowns() {
        document.querySelectorAll(".nav-dropdown.is-open").forEach((el) => {
          el.classList.remove("is-open");
          el.querySelector(".nav-dropdown-trigger")?.setAttribute(
            "aria-expanded",
            "false",
          );
        });
      }

      function setDrawer(open: boolean) {
        drawer.classList.toggle("hidden", !open);
        document.body.classList.toggle("overflow-hidden", open);
        toggle.setAttribute("aria-expanded", String(open));
        iconOpen.classList.toggle("hidden", open);
        iconClose.classList.toggle("hidden", !open);
        if (!open) closeAllDropdowns();
      }

      toggle.addEventListener("click", () => {
        setDrawer(drawer.classList.contains("hidden"));
      });
      drawer.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).tagName === "A") setDrawer(false);
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setDrawer(false);
      });

      function initNavDropdowns() {
        document.querySelectorAll(".nav-dropdown").forEach((dropdown) => {
          const trigger = dropdown.querySelector(
            ".nav-dropdown-trigger",
          ) as HTMLButtonElement | null;
          const menu = dropdown.querySelector(".nav-dropdown-menu");
          if (!trigger || !menu) return;

          const items = menu.querySelectorAll('[role="menuitem"]');

          trigger.onclick = (e) => {
            e.stopPropagation();
            const wasOpen = dropdown.classList.contains("is-open");
            closeAllDropdowns();
            if (!wasOpen) {
              dropdown.classList.add("is-open");
              trigger.setAttribute("aria-expanded", "true");
            }
          };

          trigger.onkeydown = (e) => {
            if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              dropdown.classList.add("is-open");
              trigger.setAttribute("aria-expanded", "true");
              (items[0] as HTMLElement)?.focus();
            }
          };

          menu.onmousedown = (e) => e.stopPropagation();

          items.forEach((item, index) => {
            (item as HTMLElement).onkeydown = (e) => {
              if (e.key === "ArrowDown") {
                e.preventDefault();
                (items[index + 1] ?? items[0]).focus();
              } else if (e.key === "ArrowUp") {
                e.preventDefault();
                (items[index - 1] ?? items[items.length - 1]).focus();
              } else if (e.key === "Escape") {
                closeAllDropdowns();
                trigger.focus();
              }
            };
          });
        });
      }

      initNavDropdowns();
      document.addEventListener("astro:page-load", initNavDropdowns);

      document.addEventListener("click", closeAllDropdowns);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeAllDropdowns();
      });
    </script>
  </body>
</html>

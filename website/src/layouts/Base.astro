---
import "../styles/global.css";
import { Font, Image, getImage } from "astro:assets";
import { ClientRouter, fade } from "astro:transitions";
import {
  siteName,
  siteDescription,
  siteMenu,
  footerLinks,
  homePath,
  pathMap,
  type Lang,
} from "../data/nav";
import {
  headerLogoDisplayHeight,
  headerLogoDisplayPx,
  headerLogoSizes,
  headerLogoWidths,
} from "../data/layout";
import { DISCORD_TTT, SITE_URL } from "../data/site";
import { shellLabels } from "../data/ui";
import { logo, bg, cornerOrnament } from "../data/images";
import SiteNav from "../components/SiteNav.astro";
import DiscordIcon from "../components/DiscordIcon.astro";
import LangSwitch from "../components/LangSwitch.astro";
import Lightbox from "../components/Lightbox.astro";
import CloseIcon from "../components/CloseIcon.astro";

interface Props {
  title: string;
  lang: Lang;
  /** Site-absolute path of this page, e.g. "/de/regeln/" or "/de.html". */
  path: string;
  /** Overrides the language default for meta description and social previews. */
  description?: string;
  /** Home page: hero image is LCP; defer logo fetch priority. */
  heroLcp?: boolean;
  /** Responsive preload for the home hero image. */
  lcpPreload?: { srcset: string; sizes: string };
  /** Preload Cinzel (pages with h1 page-heading). Default true. */
  preloadCinzel?: boolean;
  /** Preload Cormorant Garamond (body copy). Default true. */
  preloadCormorant?: boolean;
  /** Preload Jost (legal / small UI). Default false on content pages. */
  preloadJost?: boolean;
}

const {
  title,
  lang,
  path,
  description,
  heroLcp,
  lcpPreload,
  preloadCinzel = true,
  preloadCormorant = true,
  preloadJost = false,
} = Astro.props;

const metaDescription = description ?? siteDescription[lang];
const shareImage = `${SITE_URL}/assets/images/share.jpg`;

const menu = siteMenu[lang];
const legal = footerLinks[lang];
const alt = pathMap[path] ?? { de: "/de.html", en: "/" };
const canonical = SITE_URL + (path === "/" ? "" : path.replace(/\/$/, ""));

const bgOptimized = await getImage({ src: bg, width: 1920, format: "webp" });

const labels = shellLabels[lang];
const skipLabel = labels.skip;
const mainMenuLabel = labels.mainMenu;
const mobileMenuLabel = labels.mobileMenu;
const legalNavLabel = labels.legalNav;
const menuToggleLabel = labels.menuToggle;
---

<!doctype html>
<html lang={lang} style={`--page-bg-image: url(${bgOptimized.src})`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="440" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={shareImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png" />
    {
      lcpPreload && (
        <link
          rel="preload"
          as="image"
          imagesrcset={lcpPreload.srcset}
          imagesizes={lcpPreload.sizes}
          fetchpriority="high"
        />
      )
    }
    <Font cssVariable="--font-jost-face" preload={preloadJost} />
    <Font cssVariable="--font-cormorant-face" preload={preloadCormorant} />
    <Font cssVariable="--font-cinzel-face" preload={preloadCinzel} />
    <ClientRouter />
  </head>

  <body class="pt-(--header-height)">
    <div class="page-decor" aria-hidden="true">
      <Image
        src={cornerOrnament}
        alt=""
        width={600}
        widths={[300, 450, 600]}
        sizes="min(300px, 34vw)"
        loading="lazy"
        class="page-decor-corner page-decor-corner--left"
      />
      <Image
        src={cornerOrnament}
        alt=""
        width={600}
        widths={[300, 450, 600]}
        sizes="min(300px, 34vw)"
        loading="lazy"
        class="page-decor-corner page-decor-corner--right"
      />
    </div>

    <a href="#main-content" class="skip-link site-bar site-bar--header"
      >{skipLabel}</a
    >

    <header
      class="site-bar site-bar--header fixed inset-x-0 top-0 z-50 flex h-(--header-height) items-center gap-4 px-4 text-base lg:px-7"
    >
      <a href={homePath[lang]} class="flex h-full shrink-0 items-center py-1.5">
        <Image
          src={logo}
          alt={siteName}
          width={headerLogoDisplayPx()}
          height={headerLogoDisplayHeight()}
          widths={headerLogoWidths()}
          sizes={headerLogoSizes()}
          loading="eager"
          fetchpriority={heroLcp || lcpPreload ? undefined : "high"}
          class="block h-full w-auto"
        />
      </a>

      <SiteNav
        menu={menu}
        currentPath={path}
        variant="desktop"
        ariaLabel={mainMenuLabel}
        class="site-nav hidden flex-1 min-w-0 md:block"
      />

      <div class="ml-auto flex items-center gap-2">
        <LangSwitch lang={lang} altDe={alt.de} altEn={alt.en} />

        <DiscordIcon href={DISCORD_TTT} label="Discord" />

        <button
          type="button"
          id="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-drawer"
          aria-label={menuToggleLabel}
          class="menu-toggle"
        >
          <svg
            id="menu-icon-open"
            viewBox="0 0 24 24"
            class="h-5 w-5 fill-none stroke-current stroke-2"
            aria-hidden="true"
          >
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
          <CloseIcon id="menu-icon-close" class="hidden h-5 w-5" />
        </button>
      </div>
    </header>

    <SiteNav
      id="mobile-drawer"
      menu={menu}
      currentPath={path}
      variant="mobile"
      ariaLabel={mobileMenuLabel}
      class="site-bar site-bar--header fixed inset-x-0 top-(--header-height) z-40 hidden max-h-[calc(100vh-var(--header-height))] overflow-y-auto px-4 pb-4 pt-3 text-left text-base md:hidden!"
    />

    <main id="main-content" transition:animate={fade({ duration: "0.2s" })}>
      <slot />
    </main>

    <footer class="site-bar site-bar--footer px-4 py-4.5 text-center">
      <nav class="footer-nav" aria-label={legalNavLabel}>
        {
          legal.map((item) => (
            <a
              href={item.path}
              data-astro-prefetch
              class:list={[
                "footer-nav-link",
                item.path === path && "footer-nav-link--active",
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </footer>

    <Lightbox lang={lang} />

    <script>
      import { on, renewListenerScope } from "../lib/dom-listeners";

      let shellAbort: AbortController | null = null;
      const documentScope = new AbortController();

      function closeAllDropdowns() {
        document
          .querySelectorAll<HTMLLIElement>(".nav-dropdown.is-open")
          .forEach((el) => {
            el.classList.remove("is-open");
            el.querySelector<HTMLButtonElement>(
              ".nav-dropdown-trigger",
            )?.setAttribute("aria-expanded", "false");
          });
      }

      function setDrawer(open: boolean) {
        const toggle = document.getElementById(
          "menu-toggle",
        ) as HTMLButtonElement | null;
        const drawer = document.getElementById(
          "mobile-drawer",
        ) as HTMLElement | null;
        const iconOpen = document.getElementById(
          "menu-icon-open",
        ) as SVGElement | null;
        const iconClose = document.getElementById(
          "menu-icon-close",
        ) as SVGElement | null;
        if (!toggle || !drawer || !iconOpen || !iconClose) return;

        drawer.classList.toggle("hidden", !open);
        document.body.classList.toggle("overflow-hidden", open);
        toggle.setAttribute("aria-expanded", String(open));
        iconOpen.classList.toggle("hidden", open);
        iconClose.classList.toggle("hidden", !open);
        if (!open) closeAllDropdowns();
      }

      function initMobileMenu(signal: AbortSignal) {
        const toggle = document.getElementById(
          "menu-toggle",
        ) as HTMLButtonElement | null;
        const drawer = document.getElementById(
          "mobile-drawer",
        ) as HTMLElement | null;
        if (!toggle || !drawer) return;

        setDrawer(false);

        on(
          toggle,
          "click",
          () => {
            setDrawer(drawer.classList.contains("hidden"));
          },
          signal,
        );

        on(
          drawer,
          "click",
          (e) => {
            const link = (e.target as HTMLElement).closest(
              "a",
            ) as HTMLAnchorElement | null;
            if (link && drawer.contains(link)) setDrawer(false);
          },
          signal,
        );
      }

      function initNavDropdowns(signal: AbortSignal) {
        document
          .querySelectorAll<HTMLLIElement>(".nav-dropdown")
          .forEach((dropdown) => {
            const trigger = dropdown.querySelector<HTMLButtonElement>(
              ".nav-dropdown-trigger",
            );
            const menu =
              dropdown.querySelector<HTMLUListElement>(".nav-dropdown-menu");
            if (!trigger || !menu) return;

            const items =
              menu.querySelectorAll<HTMLAnchorElement>('[role="menuitem"]');

            on(
              trigger,
              "click",
              (e) => {
                e.stopPropagation();
                const wasOpen = dropdown.classList.contains("is-open");
                closeAllDropdowns();
                if (!wasOpen) {
                  dropdown.classList.add("is-open");
                  trigger.setAttribute("aria-expanded", "true");
                }
              },
              signal,
            );

            on(
              trigger,
              "keydown",
              (e) => {
                if (!(e instanceof KeyboardEvent)) return;
                if (
                  e.key === "ArrowDown" ||
                  e.key === "Enter" ||
                  e.key === " "
                ) {
                  e.preventDefault();
                  dropdown.classList.add("is-open");
                  trigger.setAttribute("aria-expanded", "true");
                  items[0]?.focus();
                }
              },
              signal,
            );

            on(menu, "mousedown", (e) => e.stopPropagation(), signal);

            items.forEach((item, index) => {
              on(
                item,
                "keydown",
                (e) => {
                  if (!(e instanceof KeyboardEvent)) return;
                  if (e.key === "ArrowDown") {
                    e.preventDefault();
                    (items[index + 1] ?? items[0]).focus();
                  } else if (e.key === "ArrowUp") {
                    e.preventDefault();
                    (items[index - 1] ?? items[items.length - 1]).focus();
                  } else if (e.key === "Escape") {
                    closeAllDropdowns();
                    trigger.focus();
                  }
                },
                signal,
              );
            });
          });
      }

      function initShell() {
        shellAbort = renewListenerScope(shellAbort);
        initMobileMenu(shellAbort.signal);
        initNavDropdowns(shellAbort.signal);
      }

      initShell();
      document.addEventListener("astro:page-load", initShell);

      on(document, "click", closeAllDropdowns, documentScope.signal);
      on(
        document,
        "keydown",
        (e) => {
          if (!(e instanceof KeyboardEvent) || e.key !== "Escape") return;
          setDrawer(false);
          closeAllDropdowns();
        },
        documentScope.signal,
      );
    </script>
  </body>
</html>

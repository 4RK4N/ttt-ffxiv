{
  "title": "Tickets",
  "description": "Private-thread ticket panels per category. Configure each type, save, then publish its panel to Discord.",
  "fields": [
    {
      "key": "disabled",
      "label": "Module disabled message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "noPermission",
      "label": "No permission message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "noDeletePermission",
      "label": "No delete permission message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "deleteNotClosed",
      "label": "Delete on open ticket message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "categoryUnpublished",
      "label": "Category unavailable message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "channelNotConfigured",
      "label": "Channel not configured message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "invalidChannel",
      "label": "Invalid channel message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "openError",
      "label": "Open error message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "closeError",
      "label": "Close error message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "deleteError",
      "label": "Delete error message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "closeCancelled",
      "label": "Close cancelled message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "deleteCancelled",
      "label": "Delete cancelled message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "threadContextRequired",
      "label": "Wrong context message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "invalidInteraction",
      "label": "Mismatched button message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "openInProgress",
      "label": "Open in progress message",
      "type": "textarea",
      "store": "texts"
    },
    {
      "key": "ticketTypes",
      "label": "Ticket types",
      "type": "object-list",
      "store": "config",
      "textsKey": "types",
      "itemLabel": "Ticket type",
      "itemFields": [
        {
          "key": "emoji",
          "label": "Button emoji (optional)",
          "type": "text",
          "store": "config"
        },
        {
          "key": "channelId",
          "label": "Channel",
          "type": "channel",
          "store": "config",
          "help": "Panel is posted here; ticket threads are created here."
        },
        {
          "key": "staffRoleIds",
          "label": "Staff roles",
          "type": "role-multi",
          "store": "config"
        },
        {
          "key": "deniedRoleIds",
          "label": "Denied roles",
          "type": "role-multi",
          "store": "config",
          "help": "Users with any of these roles cannot open this ticket type. Leave empty to disable."
        },
        {
          "key": "roleDenied",
          "label": "Denied role message",
          "type": "textarea",
          "store": "texts"
        },
        {
          "key": "openButtonLabel",
          "label": "Open button label",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "panelTitle",
          "label": "Panel title",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "panelDescription",
          "label": "Panel description",
          "type": "textarea",
          "store": "texts"
        },
        {
          "key": "ticketWelcome",
          "label": "Welcome message",
          "type": "textarea",
          "store": "texts",
          "help": "Tokens: {mention}"
        },
        {
          "key": "closeButtonLabel",
          "label": "Close button label",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "confirmClosePrompt",
          "label": "Close confirm prompt",
          "type": "textarea",
          "store": "texts"
        },
        {
          "key": "confirmCloseYes",
          "label": "Confirm button label",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "confirmCloseNo",
          "label": "Cancel button label",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "ticketClosed",
          "label": "Closed message",
          "type": "textarea",
          "store": "texts"
        },
        {
          "key": "deleteButtonLabel",
          "label": "Delete button label",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "confirmDeletePrompt",
          "label": "Delete confirm prompt",
          "type": "textarea",
          "store": "texts"
        },
        {
          "key": "confirmDeleteYes",
          "label": "Delete confirm button label",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "confirmDeleteNo",
          "label": "Delete cancel button label",
          "type": "text",
          "store": "texts"
        },
        {
          "key": "ticketDeleted",
          "label": "Deleted confirmation (ephemeral)",
          "type": "textarea",
          "store": "texts"
        },
        {
          "key": "alreadyOpen",
          "label": "Already open message",
          "type": "textarea",
          "store": "texts",
          "help": "Tokens: {thread}"
        },
        {
          "key": "openSuccess",
          "label": "Open success (ephemeral)",
          "type": "textarea",
          "store": "texts",
          "help": "Tokens: {thread}"
        }
      ]
    }
  ]
}
